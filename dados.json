name: Atualizar dados da fila

on:
  workflow_dispatch:
  schedule:
    # Executa diariamente. Ajuste se quiser outra frequencia.
    - cron: "17 10 * * *"

permissions:
  contents: write

jobs:
  update-data:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Setup Python
        uses: actions/setup-python@v5
        with:
          python-version: "3.11"

      - name: Install dependencies
        run: pip install -r requirements.txt

      - name: Generate dados.json
        run: python scripts/update_data.py

      - name: Commit updated data
        uses: stefanzweifel/git-auto-commit-action@v5
        with:
          commit_message: "Atualiza dados.json automaticamente"
          file_pattern: dados.json docs/raw/*.xlsx
